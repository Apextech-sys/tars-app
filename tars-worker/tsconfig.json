{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../lib/db/worker-schema.ts",
    "../lib/tars/brief/schema.ts"
  ],
  "exclude": ["node_modules", "dist", "test"]
}
