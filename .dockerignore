# Exclude large dirs that should not go into build context
.git
.github
node_modules
**/node_modules
.next
tars-worker/dist
**/.DS_Store
*.log

# Test artifacts
playwright-report
test-results
coverage

# Local env files — secrets must NOT be in the image
.env
.env.local
.env.*.local
.env.compose

# Editor / OS
.vscode
.idea
*.swp
