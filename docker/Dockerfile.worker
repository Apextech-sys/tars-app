# syntax=docker/dockerfile:1
# =============================================================================
# TARS Worker — multi-stage production image (slimmed, Iteration 1)
# Node 24 slim (Debian, glibc) — matches app image; Alpine avoided.
# NO infisical runtime dependency. Secrets via plain env vars at runtime.
# Auth: Claude Max OAuth via CLAUDE_CODE_OAUTH_TOKEN env or
#       ~/.claude/.credentials.json mount — NOT ANTHROPIC_API_KEY.
#
# Build stages:
#   base     — node + pnpm
#   deps     — full monorepo deps (tsc needs root lib/ types at build time)
#   builder  — compile tars-worker/src → tars-worker/dist
#   runner   — worker prod deps + compiled JS only. No monorepo root packages.
#              Uses npm ci (no workspace config conflicts) for the slim install.
#              Target size: <600MB (vs 3.25GB with monorepo root install).
# =============================================================================

ARG NODE_VERSION=24

# ── base ──────────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-slim AS base
RUN corepack enable && corepack prepare pnpm@latest --activate 2>/dev/null || npm install -g pnpm@latest
WORKDIR /workspace

# ── deps ──────────────────────────────────────────────────────────────────────
FROM base AS deps
# Install full workspace deps (both root + tars-worker) for the build stage.
# tsc needs root lib/ types because worker tsconfig has rootDir "..".
COPY pnpm-workspace.yaml pnpm-lock.yaml ./
COPY package.json ./
COPY tars-worker/package.json ./tars-worker/
RUN pnpm install --frozen-lockfile --ignore-scripts

# ── builder ───────────────────────────────────────────────────────────────────
FROM deps AS builder
# Full monorepo source for compilation (worker tsc includes lib/db/worker-schema.ts
# and lib/tars/brief/schema.ts via tsconfig.json "include" paths).
COPY . .
# Worker tsconfig outDir is "dist" relative to tars-worker/ but rootDir is ".."
# so compiled output lands at tars-worker/dist/tars-worker/src/index.js
RUN cd tars-worker && pnpm build

# ── runner: worker prod deps ONLY — no monorepo root ─────────────────────────
# Strategy: copy only tars-worker/package.json, generate a clean package-lock.json
# via npm, then npm ci --production. This avoids pnpm workspace/override config
# conflicts that occur when the lockfile references pnpm-workspace.yaml overrides
# but the workspace file is not present in the runner context.
FROM node:${NODE_VERSION}-slim AS runner
ENV NODE_ENV=production

RUN groupadd --system --gid 1001 nodejs && \
    useradd  --system --uid 1001 --gid nodejs tarsworker && \
    # Create home dirs for tarsworker so Claude SDK (~/.claude) and Codex SDK (~/.codex) can read/write credentials
    mkdir -p /home/tarsworker/.claude /home/tarsworker/.codex && \
    chown -R tarsworker:nodejs /home/tarsworker

WORKDIR /app

# Copy only the worker's package.json for a clean prod install
COPY --from=builder /workspace/tars-worker/package.json ./package.json

# Install worker prod dependencies using npm (avoids pnpm workspace config conflicts).
# npm resolves from package.json without needing a lockfile in this context.
RUN npm install --production --ignore-scripts --no-audit --no-fund 2>&1

# Compiled JS from the builder — the path mirrors rootDir structure under dist/:
#   tars-worker/dist/tars-worker/src/index.js
COPY --from=builder --chown=tarsworker:nodejs /workspace/tars-worker/dist ./tars-worker/dist

# Worker reads lib/tars/SOUL.md for the brief-compose handler.
# Copy it so SOUL_CANDIDATES path resolution finds it at /app/lib/tars/SOUL.md.
COPY --from=builder --chown=tarsworker:nodejs /workspace/lib/tars/SOUL.md ./lib/tars/SOUL.md

USER tarsworker

# SIGTERM is handled in src/index.ts — worker drains active jobs then exits
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=5 \
    CMD node -e "process.exit(0)"

# Direct node — NO infisical wrapper. Secrets injected by Dokploy at runtime.
CMD ["node", "tars-worker/dist/tars-worker/src/index.js"]
