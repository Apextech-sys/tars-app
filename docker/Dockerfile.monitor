# TARS dead-man / failure monitor — independent of tars-worker (so it can detect the worker being down).
# Polls Postgres every ~2 min, alerts Shaun on Slack. Managed by Dokploy (git-deploy); build context = repo root.
FROM python:3.12-slim
RUN pip install --no-cache-dir psycopg2-binary
WORKDIR /app
COPY docker/monitor.py /app/monitor.py
CMD ["sh","-c","while true; do python3 /app/monitor.py; sleep 120; done"]
