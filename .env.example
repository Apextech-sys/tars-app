# =============================================================================
# TARS env contract — copy to .env.compose (or inject via Dokploy) for local use
# NO real secrets committed here — all values are placeholders
# =============================================================================

# ── Postgres (for docker-compose tars-db service) ───────────────────────────
POSTGRES_USER=tars_app
POSTGRES_PASSWORD=changeme_db_replace_this
POSTGRES_DB=tars_app

# ── WDK runtime ─────────────────────────────────────────────────────────────
# In docker-compose the URL uses the internal service name (tars-db:5432)
# On VM 102 (direct) it's 127.0.0.1:5433
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_POSTGRES_URL=postgres://tars_app:CHANGE_ME@tars-db:5432/tars_app
WORKFLOW_POSTGRES_JOB_PREFIX=tars
WORKFLOW_POSTGRES_WORKER_CONCURRENCY=10

# ── App DB (Drizzle / Better Auth) ──────────────────────────────────────────
DATABASE_URL=postgres://tars_app:CHANGE_ME@tars-db:5432/tars_app

# ── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_32_char_random_hex
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TELEMETRY=0

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=TARS
API_URL=http://localhost:3001
APP_PORT=3001
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ── Worker callback HMAC ────────────────────────────────────────────────────
TARS_WORKER_CALLBACK_SECRET=CHANGE_ME_64_char_hex

# ── Claude / Anthropic ──────────────────────────────────────────────────────
# Worker uses this to run Claude agent jobs.
# See memory/claude-agent-sdk-billing.md — dropping this in favour of OAuth
# credential auth is tracked for Iteration 1.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Worker config (optional — all have defaults in tars-worker/src/config.ts) ─
TARS_WORKER_ID=tars-worker
TARS_WORKER_CONCURRENCY=2
TARS_APP_BASE_URL=http://tars-app:3001
LOG_LEVEL=info

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-CHANGE_ME
SLACK_USER_TOKEN=xoxp-CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME

# ── Linear ───────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_CHANGE_ME
LINEAR_WEBHOOK_SECRET=lin_wh_CHANGE_ME

# ── Internal secrets ─────────────────────────────────────────────────────────
TARS_INTERNAL_SECRET=CHANGE_ME_64_char_hex
GITHUB_WEBHOOK_SECRET=CHANGE_ME
GH_TOKEN=ghp_CHANGE_ME

# ── OpenAI (graph context only — can be a noop key) ─────────────────────────
OPENAI_API_KEY=sk-graph-context-noop-not-used
